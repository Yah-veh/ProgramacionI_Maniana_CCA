Algoritmo sin_titulo
	// C·lculo de IVA: Pedir el precio de un producto y 
	// mostrar el monto del IVA (13%) y el precio total
	
	Escribir "Ingrese el precio."
	Leer precio
	
	iva <- precio * 0.13
	total <- precio * 1.13
	
	Escribir "El IVA es: " , iva
	Escribir "El Total es: ", total
	
	Escribir "El IVA es: ", iva , " El total es: " , total
	
	// Promedio Simple: Pedir 3 notas y mostrar 
	// el promedio final (usar float).
FinAlgoritmo
