Algoritmo sin_titulo
	// Escribe un algoritmo para convertir grados 
	// Celsius a Fahrenheit (F = C * 9/5 + 32).
	
	// Ingreso de Datos
	Escribir "Ingrese los grados Celsius"
	Leer c
	
	// Proceso 
	gatito <- ( c * (9/5)) +32
	
	// Salida
	Escribir "Los grados en Fahrenheit son: " , gatito
	

FinAlgoritmo
